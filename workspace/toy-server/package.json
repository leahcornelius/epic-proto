{
  "name": "toy-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc src/index.ts src/routes/todos.ts src/auth.ts src/cli/apiKeys.ts --outDir dist --rootDir src --module commonjs --target es2020 --moduleResolution node --strict",
    "start": "node dist/index.js",
    "api-key:generate": "tsx src/cli/apiKeys.ts generate",
    "api-key:revoke": "tsx src/cli/apiKeys.ts revoke",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "express": "^4.18.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ]
  }
}
